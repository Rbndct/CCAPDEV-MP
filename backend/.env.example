# Backend Environment Variables
# Copy this to .env and fill in the values

# MongoDB connection string (from MongoDB Atlas or other provider)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/sportsplex?retryWrites=true&w=majority

# JWT secret - use a long random string in production
JWT_SECRET=replace-this-with-a-very-long-random-secret-string

# Set to 'production' on Render
NODE_ENV=development

# Port (Render sets this automatically, no need to set on Render)
PORT=5000
